# 5BIB Mobile — environment template
# Copy to `.env.local` (gitignored) and fill in values.
# Only vars prefixed with EXPO_PUBLIC_ are bundled into the client build.

# Backend REST API base URL — see eas.json per-profile overrides.
EXPO_PUBLIC_API_URL=https://api.5bib.com

# External result.5bib.com URL (in-app browser link)
EXPO_PUBLIC_RESULT_URL=https://result.5bib.com

# Sentry crash + perf monitoring
# 2 projects (org slug: 5bib, org id: o4511451510079488):
#   - prod project ID: 4511454305714176
#   - dev  project ID: 4511454317051904
# DSN switched runtime by APP_ENV trong app.config.js extra.sentryDsn — KHÔNG hardcode trong .env
# Auth token (cho source map upload) phải set qua EAS Secret hoặc env local:
#   export SENTRY_AUTH_TOKEN=<token-from-sentry-settings>
# Create token: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=

# Firebase (Analytics / Crashlytics / Cloud Messaging)
# 2 projects kế thừa team cũ:
#   - bib-60bff      → PROD (live app, 69 DAU)
#   - bib-dev-b4d19  → DEV (internal team testing)
# Project ID select theo APP_ENV trong app.config.js (KHÔNG hardcode trong .env vì swap per build)
# Note: actual config (apiKey, appId, etc.) đã trong GoogleService-Info.{prod,dev}.plist + google-services.{prod,dev}.json
EXPO_PUBLIC_FIREBASE_PROJECT_ID_PROD=bib-60bff
EXPO_PUBLIC_FIREBASE_PROJECT_ID_DEV=bib-dev-b4d19

# Facebook SDK app ID (cho FB Analytics + Login)
EXPO_PUBLIC_FB_APP_ID=

# Google Sign-In OAuth client id (iOS reverse client id type)
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# EAS project id — `eas init` writes this; also mirrored into app.json extra.eas
EXPO_PUBLIC_EAS_PROJECT_ID=
